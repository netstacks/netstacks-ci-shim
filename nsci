def cmd_stack_render(args):
    """Render all templates in a stack — dry run, no push."""
    stack = _load_stack(args.stack)
    delete_mode = getattr(args, "delete", False)

    # Force delete on all services when --delete flag is set
    if delete_mode:
        for svc_entry in stack.get("services", []):
            svc_entry["operation"] = "delete"

    mode_label = " (DELETE)" if delete_mode else ""
    print(f"Stack: {stack.get('name', args.stack)}{mode_label}")
    print(f"Description: {stack.get('description', '')}")
    print(f"Atomic: {stack.get('atomic', True)}")
    print()

    jobs = _resolve_stack_services(stack)
    _render_jobs(jobs)

    had_errors = False
    for job in jobs:
        svc = job["service"]
        dev = job["device"]
        header = f"[{svc}] → {dev}"

        if job["errors"]:
            had_errors = True
            print(f"{header}")
            for e in job["errors"]:
                print(f"  ERROR: {e}")
            print()
            continue

        driver = job["driver"]
        target = job.get("path", "?")
        op = job.get("operation", "merge")
        transport = get_transport(dev)

        if op == "delete" and not job.get("template_path"):
            # gNMI path-only delete (no template found)
            print(f"{header} (driver={driver})")
            print(f"  target: {target} (DELETE)")
            print()
        elif op == "delete" and transport == "gnmi" and job.get("rendered"):
            # gNMI delete with rendered JSON — show per-item paths
            template_path = job["template_path"]
            template_file = template_path.relative_to(LIBRARY_DIR)
            print(f"{header} (driver={driver}, template={template_file})")
            try:
                config = json.loads(job["rendered"])
                del_paths = _gnmi_delete_paths(config, target)
                for dp in del_paths:
                    print(f"  gNMI SET DELETE {dp}")
            except json.JSONDecodeError:
                print(f"  gNMI SET DELETE {target}")
            except ValueError as e:
                had_errors = True
                print(f"  ERROR: {e}")
            print()
        elif op == "delete" and transport == "netconf":
            # NETCONF delete — show XML with nc:operation="delete" injected
            template_path = job["template_path"]
            template_file = template_path.relative_to(LIBRARY_DIR)
            print(f"{header} (driver={driver}, template={template_file})")
            print(f"  target: {target} (DELETE)")
            rendered = job["rendered"]
            if 'nc:operation="delete"' not in rendered:
                try:
                    rendered = _inject_xml_delete(rendered)
                except ValueError as e:
                    had_errors = True
                    print(f"  ERROR: {e}")
                    print()
                    continue
            for line in rendered.strip().split("\n"):
                print(f"  {line}")
            print()
        else:
            template_path = job["template_path"]
            template_file = template_path.relative_to(LIBRARY_DIR)
            print(f"{header} (driver={driver}, template={template_file})")
            print(f"  target: {target} ({op})")
            for line in job["rendered"].strip().split("\n"):
                print(f"  {line}")
            print()

    # Summary
    devices = sorted(set(j["device"] for j in jobs))
    services = sorted(set(j["service"] for j in jobs))
    errors = sum(1 for j in jobs if j["errors"])
    print("-" * 60)
    print(f"Services: {', '.join(services)}")
    print(f"Devices:  {', '.join(devices)}")
    print(f"Jobs:     {len(jobs)} total, {len(jobs) - errors} OK, {errors} errors")

    return 1 if had_errors else 0


def cmd_stack_deploy(args):
    """Deploy a stack: render → push (commit-confirm) → validate → confirm → sync.

    Full pipeline:
      1. Render:      resolve all services × devices, render Jinja2 templates
      2. Pre-flight:  snapshot current config from each device (rollback point)
      3. Push:        send rendered templates to devices
                      - NETCONF w/ commit-confirm: edit candidate → confirmed commit (timer starts)
                      - NETCONF w/o commit-confirm: edit-config merge on running
                      - gNMI: Set update (immediate, no commit-confirm)
      4. Validate:    verify rendered sections are present on devices
      5. Confirm:     send confirming commit to NETCONF devices (stops rollback timer)
                      If validation fails and atomic: DON'T confirm → timer expires → auto-rollback
      6. Sync:        pull full config back from each device, save to configs/
    """
    stack = _load_stack(args.stack)
    stack_name = stack.get("name", args.stack)
    atomic = stack.get("atomic", True)
    workers = stack.get("workers", 10)

    print(f"Stack: {stack_name}")
    print(f"Description: {stack.get('description', '')}")
    print(f"Atomic: {atomic}")
    print()

    # --- Stage 1: Render ---
    print("Stage 1: Rendering templates...")
    jobs = _resolve_stack_services(stack)
    _render_jobs(jobs)

    error_jobs = [j for j in jobs if j["errors"]]
    if error_jobs:
        for j in error_jobs:
            for e in j["errors"]:
                print(f"  [{j['service']}] {j['device']}: {e}")
        print(f"\nABORTED: {len(error_jobs)} jobs failed to render. No changes made.")
        return 1

    all_devices = list(dict.fromkeys(j["device"] for j in jobs))
    all_services = sorted(set(j["service"] for j in jobs))
    workers = min(len(all_devices), workers)

    # Show which devices support commit-confirm
    confirm_devices = set()
    for name in all_devices:
        device = get_device(name)
        driver = load_driver(device["driver"])
        if driver:
            caps = driver.get("capabilities", {})
            has_cc = caps.get("commit_confirm", False) and caps.get("candidate_datastore", False)
            cc_label = " (commit-confirm)" if has_cc else ""
            if has_cc:
                confirm_devices.add(name)
        else:
            cc_label = ""
        device_jobs = [j for j in jobs if j["device"] == name]
        for job in device_jobs:
            tmpl = job["template_path"].relative_to(LIBRARY_DIR)
            print(f"  [{job['service']}] → {name} ({job['driver']}{cc_label}, {tmpl})")

    print(f"\n  {len(jobs)} jobs rendered OK")
    if confirm_devices:
        print(f"  Commit-confirm devices: {', '.join(sorted(confirm_devices))}")
    print()

    # --- Stage 2: Pre-flight ---
    print("Stage 2: Pre-flight (saving rollback snapshots)...")
    rollbacks = {}
    preflight_failures = []

    def preflight_one(name):
        try:
            config, fmt = transport_pull(name)
            return name, config, fmt, None
        except Exception as e:
            return name, None, None, str(e)

    with concurrent.futures.ThreadPoolExecutor(max_workers=workers) as pool:
        futures = {pool.submit(preflight_one, n): n for n in all_devices}
        for future in concurrent.futures.as_completed(futures):
            name, config, fmt, error = future.result()
            if error:
                print(f"  {name}: FAILED — {error}")
                preflight_failures.append(name)
            else:
                rollbacks[name] = (config, fmt)
                print(f"  {name}: OK")

    if preflight_failures:
        print(f"\nABORTED: {len(preflight_failures)} devices unreachable. No changes made.")
        return 1

    print()

    # --- Stage 3: Push rendered templates ---
    print("Stage 3: Pushing rendered templates...")
    push_results = {}  # (service, device) -> (success, error, metadata)

    def push_one_job(job):
        svc = job["service"]
        dev = job["device"]
        try:
            result = transport_push_partial(
                dev, job["rendered"], job["template_path"],
                target_path=job.get("path"),
                operation=job.get("operation", "merge"),
            )
            return svc, dev, True, None, result
        except Exception as e:
            return svc, dev, False, str(e), {}

    def push_device_jobs(device_jobs):
        """Push all jobs for one device sequentially (avoids write-lock races)."""
        results = []
        for job in device_jobs:
            results.append(push_one_job(job))
        return results

    # Group jobs by device — serialize within device, parallelize across devices
    from collections import defaultdict
    jobs_by_device = defaultdict(list)
    for j in jobs:
        jobs_by_device[j["device"]].append(j)

    with concurrent.futures.ThreadPoolExecutor(max_workers=workers) as pool:
        futures = {pool.submit(push_device_jobs, dj): dev for dev, dj in jobs_by_device.items()}
        for future in concurrent.futures.as_completed(futures):
            for svc, dev, success, error, meta in future.result():
                push_results[(svc, dev)] = (success, error, meta)
                if success:
                    cc = " (confirmed-commit pending)" if meta.get("confirmed_commit") else ""
                    print(f"  [{svc}] → {dev}: PUSHED{cc}")
                else:
                    print(f"  [{svc}] → {dev}: FAILED — {error}")

    push_failed = [(s, d) for (s, d), (ok, _, _) in push_results.items() if not ok]

    # Track which devices have pending confirmed-commits
    pending_confirm = set()
    for (svc, dev), (ok, _, meta) in push_results.items():
        if ok and meta.get("confirmed_commit"):
            pending_confirm.add(dev)

    print()

    # --- Stage 4: Validate ---
    failed_devices = set()
    if push_failed:
        failed_devices.update(d for _, d in push_failed)
    else:
        print("Stage 4: Validating...")

        def _strip_oc_prefix(key):
            """Strip OpenConfig module prefix from key (e.g. 'openconfig-system:servers' → 'servers')."""
            return key.split(":", 1)[1] if ":" in key else key

        def _find_key(key, d):
            """Find a key in dict, ignoring OpenConfig module prefixes."""
            if key in d:
                return key
            bare = _strip_oc_prefix(key)
            for k in d:
                if _strip_oc_prefix(k) == bare:
                    return k
            return None

        def _deep_check(expected, actual, path=""):
            """Recursively check that all keys/values in expected exist in actual.

            Returns list of mismatch descriptions.
            """
            mismatches = []
            if isinstance(expected, dict):
                if not isinstance(actual, dict):
                    return [f"{path}: expected dict, got {type(actual).__name__}"]
                for key in expected:
                    actual_key = _find_key(key, actual)
                    if actual_key is None:
                        mismatches.append(f"{path}.{key}: MISSING")
                    else:
                        mismatches.extend(_deep_check(expected[key], actual[actual_key], f"{path}.{key}"))
            elif isinstance(expected, list):
                if not isinstance(actual, list):
                    return [f"{path}: expected list, got {type(actual).__name__}"]
                # Match list items by key fields (name, address, prefix, etc.)
                key_fields = ["name", "address", "prefix", "neighbor-address",
                              "community-set-name", "index"]
                list_key = None
                for kf in key_fields:
                    if expected and isinstance(expected[0], dict) and kf in expected[0]:
                        list_key = kf
                        break
                if list_key:
                    actual_by_key = {}
                    for item in actual:
                        if isinstance(item, dict) and list_key in item:
                            actual_by_key[str(item[list_key])] = item
                    for item in expected:
                        if isinstance(item, dict) and list_key in item:
                            k = str(item[list_key])
                            if k not in actual_by_key:
                                mismatches.append(f"{path}[{list_key}={k}]: MISSING")
                            else:
                                mismatches.extend(_deep_check(item, actual_by_key[k],
                                                              f"{path}[{list_key}={k}]"))
                else:
                    # No key field — check by index
                    for i, item in enumerate(expected):
                        if i >= len(actual):
                            mismatches.append(f"{path}[{i}]: MISSING")
                        else:
                            mismatches.extend(_deep_check(item, actual[i], f"{path}[{i}]"))
            else:
                if not _values_match(expected, actual):
                    mismatches.append(f"{path}: expected {expected!r}, got {actual!r}")
            return mismatches

        def _values_match(expected, actual):
            """Compare values, handling BGP community format differences.

            Arista returns communities as integers (65000*65536+100 = 4259840100)
            while templates use 'AS:value' string format ('65000:100').
            """
            if str(expected) == str(actual):
                return True
            # BGP community: "AS:value" string vs numeric encoding
            exp_str = str(expected)
            if ":" in exp_str:
                parts = exp_str.split(":", 1)
                try:
                    numeric = int(parts[0]) * 65536 + int(parts[1])
                    if str(numeric) == str(actual):
                        return True
                except (ValueError, IndexError):
                    pass
            return False

        def validate_one(name):
            """Validate all jobs for a device. Returns (name, ok, details)."""
            device = get_device(name)
            driver = load_driver(device["driver"])
            transport = driver["transport"]
            device_jobs = [j for j in jobs if j["device"] == name]
            issues = []

            for job in device_jobs:
                svc = job["service"]
                target = job.get("path")

                if job["fmt"] == "json" and transport == "gnmi" and target:
                    # Pull the specific section via gNMI Get and deep compare
                    try:
                        live_section = gnmi_get_section(device, target)
                        rendered_dict = json.loads(job["rendered"])
                        mismatches = _deep_check(rendered_dict, live_section)
                        for m in mismatches:
                            issues.append(f"[{svc}] {m}")
                    except Exception as e:
                        issues.append(f"[{svc}] validation read failed: {e}")
                elif job["fmt"] == "json":
                    # Fallback: pull full config, check rendered keys exist
                    try:
                        live_config, _ = transport_pull(name)
                        rendered_dict = json.loads(job["rendered"])
                        for key in rendered_dict:
                            if key not in live_config:
                                issues.append(f"[{svc}] missing section: {key}")
                    except Exception as e:
                        issues.append(f"[{svc}] validation read failed: {e}")
                else:
                    # NETCONF/XML — pull full config, basic sanity check
                    try:
                        transport_pull(name)
                        # Device responded — config is at least not broken
                    except Exception as e:
                        issues.append(f"[{svc}] device unreachable after push: {e}")

            return name, len(issues) == 0, issues

        with concurrent.futures.ThreadPoolExecutor(max_workers=workers) as pool:
            futures = {pool.submit(validate_one, n): n for n in all_devices}
            for future in concurrent.futures.as_completed(futures):
                name, ok, issues = future.result()
                if ok:
                    print(f"  {name}: OK")
                else:
                    for issue in issues:
                        print(f"  {name}: FAIL — {issue}")
                    failed_devices.add(name)

        print()

    # --- Stage 5: Confirm or Rollback ---
    if failed_devices and atomic:
        if pending_confirm:
            print(f"Stage 5: VALIDATION FAILED — letting commit-confirm timers expire...")
            print(f"  Devices with pending confirmed-commits will auto-rollback:")
            for name in sorted(pending_confirm):
                device = get_device(name)
                driver = load_driver(device["driver"])
                timeout = driver.get("capabilities", {}).get("commit_confirm_timeout", 120)
                print(f"  {name}: will auto-rollback in {timeout}s (NOT confirming)")

        # For devices without commit-confirm (gNMI), do manual rollback
        manual_rollback = [n for n in all_devices if n not in pending_confirm]
        if manual_rollback:
            print(f"\n  Manually rolling back {len(manual_rollback)} devices without commit-confirm...")

            def rollback_one(name):
                config, fmt = rollbacks[name]
                try:
                    transport_push_full(name, config)
                    return name, True, None
                except Exception as e:
                    return name, False, str(e)

            with concurrent.futures.ThreadPoolExecutor(max_workers=workers) as pool:
                futures = {pool.submit(rollback_one, n): n for n in manual_rollback}
                for future in concurrent.futures.as_completed(futures):
                    name, success, error = future.result()
                    if success:
                        print(f"  {name}: ROLLED BACK")
                    else:
                        print(f"  {name}: ROLLBACK FAILED — {error} (MANUAL INTERVENTION NEEDED)")

        # Sync configs back to pre-deploy state
        print()
        print("  Syncing configs/ to rolled-back state...")
        for name in all_devices:
            config, fmt = rollbacks[name]
            if fmt == "json":
                save_config(name, config)
            else:
                CONFIGS_DIR.mkdir(parents=True, exist_ok=True)
                path = CONFIGS_DIR / f"{name}.xml"
                with open(path, "w") as f:
                    f.write(config)

        print(f"\nDEPLOY FAILED — all devices rolled back to previous state.")
        return 1

    elif failed_devices and not atomic:
        succeeded_devices = [d for d in all_devices if d not in failed_devices]
        # Confirm successful devices that have pending commits
        for name in succeeded_devices:
            if name in pending_confirm:
                try:
                    transport_confirm(name)
                    print(f"  {name}: confirmed")
                except Exception as e:
                    print(f"  {name}: CONFIRM FAILED — {e}")
        print(f"WARNING: {len(failed_devices)} devices had failures (non-atomic mode)")
        print(f"  Failed:    {', '.join(sorted(failed_devices))}")
        print(f"  Succeeded: {', '.join(succeeded_devices)}")
        return 1

    else:
        # All good — confirm all pending confirmed-commits
        if pending_confirm:
            print("Stage 5: Confirming commits...")
            for name in sorted(pending_confirm):
                try:
                    transport_confirm(name)
                    print(f"  {name}: CONFIRMED")
                except Exception as e:
                    print(f"  {name}: CONFIRM FAILED — {e} (device may auto-rollback!)")
                    failed_devices.add(name)

            if failed_devices:
                print(f"\nDEPLOY FAILED — some devices could not be confirmed.")
                return 1

            print()

        # --- Stage 6: Sync configs/ ---
        print("Stage 6: Syncing configs/...")

        def sync_one(name):
            try:
                config, fmt = transport_pull(name)
                if fmt == "json":
                    save_config(name, config)
                else:
                    CONFIGS_DIR.mkdir(parents=True, exist_ok=True)
                    path = CONFIGS_DIR / f"{name}.xml"
                    with open(path, "w") as f:
                        f.write(config)
                return name, True, None
            except Exception as e:
                return name, False, str(e)

        with concurrent.futures.ThreadPoolExecutor(max_workers=workers) as pool:
            futures = {pool.submit(sync_one, n): n for n in all_devices}
            for future in concurrent.futures.as_completed(futures):
                name, success, error = future.result()
                if success:
                    print(f"  {name}: synced")
                else:
                    print(f"  {name}: sync failed ��� {error}")

        print()
        print(f"STACK DEPLOY SUCCEEDED — {stack_name}")
        print(f"  {len(jobs)} service configs pushed to {len(all_devices)} devices")
        if pending_confirm:
            print(f"  {len(pending_confirm)} devices confirmed via commit-confirm")
        print(f"  configs/ synced with live state")
        return 0


def cmd_stack_delete(args):
    """Delete all config deployed by a stack.

    Uses the same stack.yaml as deploy, but removes config instead of pushing it.

    For gNMI:    Set delete at the schema path (no payload needed)
    For NETCONF: Render template for XML structure, inject nc:operation="delete",
                 push via edit-config. Delete-specific templates (delete.*.j2) are
                 used when available for finer control.

    Pipeline: Resolve → Render → Pre-flight → Delete → Confirm → Sync
    """
    stack = _load_stack(args.stack)
    stack_name = stack.get("name", args.stack)
    atomic = stack.get("atomic", True)
    workers = stack.get("workers", 10)

    # Force operation: delete on all services
    for svc_entry in stack.get("services", []):
        svc_entry["operation"] = "delete"

    print(f"Stack: {stack_name} (DELETE)")
    print(f"Description: {stack.get('description', '')}")
    print(f"Atomic: {atomic}")
    print()

    # --- Stage 1: Resolve & Render ---
    print("Stage 1: Resolving delete targets...")
    jobs = _resolve_stack_services(stack)
    _render_jobs(jobs)

    error_jobs = [j for j in jobs if j["errors"]]
    if error_jobs:
        for j in error_jobs:
            for e in j["errors"]:
                print(f"  [{j['service']}] {j['device']}: {e}")
        print(f"\nABORTED: {len(error_jobs)} jobs failed. No changes made.")
        return 1

    all_devices = list(dict.fromkeys(j["device"] for j in jobs))
    workers = min(len(all_devices), workers)

    # Show what will be deleted
    confirm_devices = set()
    for name in all_devices:
        device = get_device(name)
        driver = load_driver(device["driver"])
        if driver:
            caps = driver.get("capabilities", {})
            has_cc = caps.get("commit_confirm", False) and caps.get("candidate_datastore", False)
            cc_label = " (commit-confirm)" if has_cc else ""
            if has_cc:
                confirm_devices.add(name)
        else:
            cc_label = ""
        device_jobs = [j for j in jobs if j["device"] == name]
        for job in device_jobs:
            target = job.get("path", "?")
            transport = get_transport(name)
            if transport == "gnmi" and job.get("rendered"):
                try:
                    config = json.loads(job["rendered"])
                    del_paths = _gnmi_delete_paths(config, target)
                    for dp in del_paths:
                        print(f"  [{job['service']}] → {name}: DELETE {dp}")
                except (json.JSONDecodeError, ValueError):
                    print(f"  [{job['service']}] → {name}: DELETE {target}")
            elif transport == "gnmi":
                print(f"  [{job['service']}] → {name}: DELETE {target}")
            else:
                tmpl_name = job["template_path"].name if job.get("template_path") else "path-only"
                print(f"  [{job['service']}] → {name}: DELETE via {tmpl_name}{cc_label}")

    print(f"\n  {len(jobs)} deletions planned")
    if confirm_devices:
        print(f"  Commit-confirm devices: {', '.join(sorted(confirm_devices))}")
    print()

    # --- Stage 2: Pre-flight ---
    print("Stage 2: Pre-flight (saving rollback snapshots)...")
    rollbacks = {}
    preflight_failures = []

    def preflight_one(name):
        try:
            config, fmt = transport_pull(name)
            return name, config, fmt, None
        except Exception as e:
            return name, None, None, str(e)

    with concurrent.futures.ThreadPoolExecutor(max_workers=workers) as pool:
        futures = {pool.submit(preflight_one, n): n for n in all_devices}
        for future in concurrent.futures.as_completed(futures):
            name, config, fmt, error = future.result()
            if error:
                print(f"  {name}: FAILED — {error}")
                preflight_failures.append(name)
            else:
                rollbacks[name] = (config, fmt)
                print(f"  {name}: OK")

    if preflight_failures:
        print(f"\nABORTED: {len(preflight_failures)} devices unreachable. No changes made.")
        return 1

    print()

    # --- Stage 3: Delete ---
    print("Stage 3: Deleting config...")
    push_results = {}

    def delete_one_job(job):
        svc = job["service"]
        dev = job["device"]
        try:
            result = transport_push_partial(
                dev, job.get("rendered", ""), job.get("template_path"),
                target_path=job.get("path"), operation="delete",
            )
            return svc, dev, True, None, result
        except Exception as e:
            return svc, dev, False, str(e), {}

    def delete_device_jobs(device_jobs):
        """Delete all jobs for one device sequentially (avoids write-lock races)."""
        results = []
        for job in device_jobs:
            results.append(delete_one_job(job))
        return results

    # Group jobs by device — serialize within device, parallelize across devices
    from collections import defaultdict
    jobs_by_device = defaultdict(list)
    for j in jobs:
        jobs_by_device[j["device"]].append(j)

    with concurrent.futures.ThreadPoolExecutor(max_workers=workers) as pool:
        futures = {pool.submit(delete_device_jobs, dj): dev for dev, dj in jobs_by_device.items()}
        for future in concurrent.futures.as_completed(futures):
            for svc, dev, success, error, meta in future.result():
                push_results[(svc, dev)] = (success, error, meta)
                if success:
                    cc = " (confirmed-commit pending)" if meta.get("confirmed_commit") else ""
                    print(f"  [{svc}] → {dev}: DELETED{cc}")
                else:
                    print(f"  [{svc}] → {dev}: FAILED — {error}")

    push_failed = [(s, d) for (s, d), (ok, _, _) in push_results.items() if not ok]

    pending_confirm = set()
    for (svc, dev), (ok, _, meta) in push_results.items():
        if ok and meta.get("confirmed_commit"):
            pending_confirm.add(dev)

    print()

    # --- Stage 4: Confirm or Rollback ---
    failed_devices = set(d for _, d in push_failed)

    if failed_devices and atomic:
        if pending_confirm:
            print(f"Stage 4: DELETE FAILED — letting commit-confirm timers expire...")
            for name in sorted(pending_confirm):
                device = get_device(name)
                driver = load_driver(device["driver"])
                timeout = driver.get("capabilities", {}).get("commit_confirm_timeout", 120)
                print(f"  {name}: will auto-rollback in {timeout}s (NOT confirming)")

        manual_rollback = [n for n in all_devices if n not in pending_confirm]
        if manual_rollback:
            print(f"\n  Rolling back {len(manual_rollback)} devices...")
            def rollback_one(name):
                config, fmt = rollbacks[name]
                try:
                    transport_push_full(name, config)
                    return name, True, None
                except Exception as e:
                    return name, False, str(e)

            with concurrent.futures.ThreadPoolExecutor(max_workers=workers) as pool:
                futures = {pool.submit(rollback_one, n): n for n in manual_rollback}
                for future in concurrent.futures.as_completed(futures):
                    name, success, error = future.result()
                    if success:
                        print(f"  {name}: ROLLED BACK")
                    else:
                        print(f"  {name}: ROLLBACK FAILED — {error} (MANUAL INTERVENTION NEEDED)")

        print(f"\nDELETE FAILED — devices rolled back.")
        return 1

    else:
        if pending_confirm:
            print("Stage 4: Confirming deletes...")
            for name in sorted(pending_confirm):
                try:
                    transport_confirm(name)
                    print(f"  {name}: CONFIRMED")
                except Exception as e:
                    print(f"  {name}: CONFIRM FAILED — {e}")
                    failed_devices.add(name)

            if failed_devices:
                print(f"\nDELETE FAILED — some devices could not be confirmed.")
                return 1
            print()

    # --- Stage 5: Sync ---
    print("Stage 5: Syncing configs/...")
    for name in all_devices:
        try:
            config, fmt = transport_pull(name)
            if fmt == "json":
                save_config(name, config)
            else:
                CONFIGS_DIR.mkdir(parents=True, exist_ok=True)
                path = CONFIGS_DIR / f"{name}.xml"
                with open(path, "w") as f:
                    f.write(config)
            print(f"  {name}: synced")
        except Exception as e:
            print(f"  {name}: sync failed — {e}")

    print(f"\nDELETE COMPLETE — {stack_name}")
    print(f"  {len(jobs)} services removed from {len(all_devices)} devices")
    return 0


