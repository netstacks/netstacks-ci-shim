#!/usr/bin/env python3
"""nsci - NetStacks CI

Git-native network configuration management. Device configs live as
structured JSON files in a Git repo. Changes are pushed to devices via
gNMI, NETCONF, or REST APIs. The device handles the "how" — adds,
removes, and modifications are all a single replace operation.

https://github.com/netstacks/netstacks-ci
"""

import argparse
import json
import subprocess
import sys
from pathlib import Path

import yaml

REPO_ROOT = Path(__file__).resolve().parent
INVENTORY_FILE = REPO_ROOT / "inventory.yaml"
CONFIGS_DIR = REPO_ROOT / "configs"
STACKS_DIR = REPO_ROOT / "stacks"
LIBRARY_DIR = REPO_ROOT / "library"
DRIVERS_DIR = REPO_ROOT / "drivers"


# ---------------------------------------------------------------------------
# Inventory
# ---------------------------------------------------------------------------

def load_inventory():
    with open(INVENTORY_FILE) as f:
        return yaml.safe_load(f).get("devices", {})


def get_device(name):
    inv = load_inventory()
    if name not in inv:
        print(f"Error: device '{name}' not in inventory")
        sys.exit(1)
    return inv[name]


# ---------------------------------------------------------------------------
# gNMI transport
# ---------------------------------------------------------------------------

def gnmi_connect(device):
    from pygnmi.client import gNMIclient
    cred = device["credential"]
    return gNMIclient(
        target=(device["hostname"], device.get("gnmi_port", 6030)),
        username=cred["username"],
        password=cred["password"],
        insecure=True,
        skip_verify=True,
        gnmi_timeout=30,
    )


def gnmi_pull(device):
    """Pull full config from device via gNMI Get."""
    with gnmi_connect(device) as gc:
        result = gc.get(path=["/"], datatype="config", encoding="json_ietf")
        return result["notification"][0]["update"][0]["val"]


def gnmi_push(device, config):
    """Push full config to device via gNMI Set replace."""
    with gnmi_connect(device) as gc:
        result = gc.set(replace=[("/", config)], encoding="json_ietf")
        return result


def gnmi_get_section(device, path):
    """Pull a specific config section via gNMI Get."""
    with gnmi_connect(device) as gc:
        result = gc.get(path=[path], datatype="config", encoding="json_ietf")
        return result["notification"][0]["update"][0]["val"]


# ---------------------------------------------------------------------------
# Config file helpers
# ---------------------------------------------------------------------------

def config_path(device_name):
    return CONFIGS_DIR / f"{device_name}.json"


def load_config(device_name):
    path = config_path(device_name)
    if not path.exists():
        print(f"No config file for {device_name}. Run: shim pull {device_name}")
        sys.exit(1)
    with open(path) as f:
        return json.load(f)


def save_config(device_name, config):
    CONFIGS_DIR.mkdir(parents=True, exist_ok=True)
    path = config_path(device_name)
    with open(path, "w") as f:
        json.dump(config, f, indent=2)
        f.write("\n")
    return path


# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

def cmd_pull(args):
    """Pull device config into configs/<device>.json."""
    device_name = args.device
    device = get_device(device_name)

    print(f"Pulling config from {device_name} ({device['hostname']})...")
    config = gnmi_pull(device)

    path = save_config(device_name, config)
    keys = sorted(k.split(":")[-1] for k in config.keys())
    print(f"Saved: {path.relative_to(REPO_ROOT)}")
    print(f"Sections: {', '.join(keys)}")


def cmd_push(args):
    """Push configs/<device>.json to a single device."""
    device_name = args.device
    device = get_device(device_name)
    config = load_config(device_name)

    print(f"Pushing config to {device_name} ({device['hostname']})...")
    try:
        result = gnmi_push(device, config)
        op = result["response"][0]["op"]
        print(f"gNMI Set: {op}")
        print(f"Device config replaced from {config_path(device_name).relative_to(REPO_ROOT)}")
    except Exception as e:
        print(f"PUSH FAILED for {device_name}: {e}")
        return 1


def cmd_deploy(args):
    """Deploy config to multiple devices: parallel push with atomic rollback.

    Stages:
      1. Pre-flight: pull current config from each device (save as rollback)
      2. Push: send new config to all devices in parallel
      3. Validate: check all devices match expected state
      4. Rollback: if any device failed, restore all to pre-flight state
    """
    import concurrent.futures

    device_names = args.devices
    if not device_names:
        print("No devices specified.")
        return 1

    workers = min(len(device_names), args.workers)
    atomic = not args.no_atomic

    print(f"Deploy to {len(device_names)} devices (workers={workers}, atomic={atomic})")
    print(f"  Devices: {', '.join(device_names)}")
    print()

    # --- Stage 1: Pre-flight — pull current configs as rollback snapshots ---
    print("Stage 1: Pre-flight (saving rollback snapshots)...")
    rollbacks = {}  # device_name -> current config from device
    preflight_failures = []

    def preflight_one(name):
        device = get_device(name)
        try:
            config = gnmi_pull(device)
            return name, config, None
        except Exception as e:
            return name, None, str(e)

    with concurrent.futures.ThreadPoolExecutor(max_workers=workers) as pool:
        futures = {pool.submit(preflight_one, n): n for n in device_names}
        for future in concurrent.futures.as_completed(futures):
            name, config, error = future.result()
            if error:
                print(f"  {name}: FAILED pre-flight — {error}")
                preflight_failures.append(name)
            else:
                rollbacks[name] = config
                print(f"  {name}: OK (snapshot saved)")

    if preflight_failures:
        print(f"\nABORTED: {len(preflight_failures)} devices failed pre-flight. No changes made.")
        return 1

    print()

    # --- Stage 2: Push — send new configs in parallel ---
    print("Stage 2: Pushing configs...")
    push_results = {}  # device_name -> (success, error)

    def push_one(name):
        device = get_device(name)
        path = config_path(name)
        if not path.exists():
            return name, False, f"no config file (run: shim pull {name})"
        with open(path) as f:
            config = json.load(f)
        try:
            gnmi_push(device, config)
            return name, True, None
        except Exception as e:
            return name, False, str(e)

    with concurrent.futures.ThreadPoolExecutor(max_workers=workers) as pool:
        futures = {pool.submit(push_one, n): n for n in device_names}
        for future in concurrent.futures.as_completed(futures):
            name, success, error = future.result()
            push_results[name] = (success, error)
            if success:
                print(f"  {name}: PUSHED")
            else:
                print(f"  {name}: FAILED — {error}")

    failed = [n for n, (s, _) in push_results.items() if not s]
    succeeded = [n for n, (s, _) in push_results.items() if s]
    print()

    # --- Stage 3: Validate ---
    if succeeded:
        print("Stage 3: Validating...")
        validate_failures = []

        def validate_one(name):
            device = get_device(name)
            local_config = load_config(name)
            try:
                live_config = gnmi_pull(device)
                local_str = json.dumps(local_config, sort_keys=True)
                live_str = json.dumps(live_config, sort_keys=True)
                return name, local_str == live_str, None
            except Exception as e:
                return name, False, str(e)

        with concurrent.futures.ThreadPoolExecutor(max_workers=workers) as pool:
            futures = {pool.submit(validate_one, n): n for n in succeeded}
            for future in concurrent.futures.as_completed(futures):
                name, valid, error = future.result()
                if valid:
                    print(f"  {name}: IN SYNC")
                else:
                    reason = error or "config mismatch"
                    print(f"  {name}: VALIDATION FAILED — {reason}")
                    validate_failures.append(name)

        failed.extend(validate_failures)
        print()

    # --- Stage 4: Rollback if atomic and any failures ---
    if failed and atomic:
        print(f"Stage 4: ROLLING BACK ({len(failed)} failures, atomic mode)")
        print(f"  Restoring all {len(device_names)} devices to pre-flight state...")

        def rollback_one(name):
            device = get_device(name)
            try:
                gnmi_push(device, rollbacks[name])
                return name, True, None
            except Exception as e:
                return name, False, str(e)

        with concurrent.futures.ThreadPoolExecutor(max_workers=workers) as pool:
            futures = {pool.submit(rollback_one, n): n for n in device_names}
            for future in concurrent.futures.as_completed(futures):
                name, success, error = future.result()
                if success:
                    print(f"  {name}: ROLLED BACK")
                else:
                    print(f"  {name}: ROLLBACK FAILED — {error} (MANUAL INTERVENTION NEEDED)")

        print(f"\nDEPLOY FAILED — all devices rolled back to previous state.")
        return 1

    elif failed and not atomic:
        print(f"WARNING: {len(failed)} devices failed (non-atomic mode, no rollback)")
        print(f"  Failed: {', '.join(failed)}")
        print(f"  Succeeded: {', '.join(succeeded)}")
        return 1

    else:
        print(f"DEPLOY SUCCEEDED — {len(succeeded)} devices updated.")
        return 0


def cmd_stack_deploy(args):
    """Deploy using a stack definition from stacks/."""
    stack_name = args.stack
    stack_path = STACKS_DIR / stack_name / "stack.yaml"

    if not stack_path.exists():
        print(f"Stack '{stack_name}' not found.")
        if STACKS_DIR.exists():
            available = [d.name for d in STACKS_DIR.iterdir() if (d / "stack.yaml").exists()]
            if available:
                print(f"Available: {', '.join(available)}")
        return 1

    service = yaml.safe_load(open(stack_path))
    print(f"Service: {service.get('name', service_name)}")
    print(f"Description: {service.get('description', '')}")
    print()

    # Build args for cmd_deploy
    class DeployArgs:
        pass

    deploy_args = DeployArgs()
    deploy_args.devices = service["devices"]
    deploy_args.workers = service.get("workers", 10)
    deploy_args.no_atomic = not service.get("atomic", True)

    return cmd_deploy(deploy_args)


def cmd_stack_list(args):
    """List available stacks."""
    if not STACKS_DIR.exists():
        print("No stacks defined. Create directories in stacks/")
        return

    print(f"{'Stack':<25} {'Atomic':<10} {'Devices':<8} Description")
    print("-" * 80)
    for d in sorted(STACKS_DIR.iterdir()):
        stack_file = d / "stack.yaml"
        if not stack_file.exists():
            continue
        stack = yaml.safe_load(open(stack_file))
        name = stack.get("name", d.name)
        atomic = "yes" if stack.get("atomic", True) else "no"
        devices = len(stack.get("devices", []))
        desc = stack.get("description", "")
        print(f"{name:<25} {atomic:<10} {devices:<8} {desc}")


def cmd_diff(args):
    """Compare local config file vs live device."""
    device_name = args.device
    device = get_device(device_name)
    local_config = load_config(device_name)

    print(f"Pulling live config from {device_name}...")
    live_config = gnmi_pull(device)

    # Deep compare
    try:
        from deepdiff import DeepDiff
        diff = DeepDiff(live_config, local_config, ignore_order=True)
    except ImportError:
        # Fallback: simple JSON comparison
        if json.dumps(live_config, sort_keys=True) == json.dumps(local_config, sort_keys=True):
            diff = {}
        else:
            diff = {"note": "install deepdiff for detailed diff"}

    if not diff:
        print(f"{device_name}: no differences (file matches device)")
    else:
        print(f"{device_name}: differences found")
        print()
        if hasattr(diff, 'to_dict'):
            d = diff.to_dict()
        else:
            d = diff

        for change_type, changes in d.items():
            print(f"  {change_type}:")
            if isinstance(changes, dict):
                for path, detail in list(changes.items())[:20]:
                    print(f"    {path}: {detail}")
            elif isinstance(changes, list):
                for item in changes[:20]:
                    print(f"    {item}")
            else:
                print(f"    {changes}")
            print()


def cmd_validate(args):
    """Check if device matches the config file."""
    device_name = args.device
    device = get_device(device_name)
    local_config = load_config(device_name)

    print(f"Validating {device_name} ({device['hostname']})...")
    live_config = gnmi_pull(device)

    # Compare
    local_str = json.dumps(local_config, sort_keys=True)
    live_str = json.dumps(live_config, sort_keys=True)

    if local_str == live_str:
        print(f"IN SYNC: {device_name} matches config file")
        return 0
    else:
        print(f"DRIFT: {device_name} does not match config file")
        print(f"  Run 'shim diff {device_name}' for details")
        print(f"  Run 'shim push {device_name}' to fix")
        return 1


def cmd_show(args):
    """Browse device config in a readable format."""
    device_name = args.device
    config = load_config(device_name)
    section = args.section

    if not section:
        # Top-level overview
        print(f"{device_name} config sections:")
        print()
        for key in sorted(config.keys()):
            display = key.split(":")[-1]
            val = config[key]
            if isinstance(val, dict):
                subkeys = [k.split(":")[-1] for k in val.keys()]
                print(f"  {display}/")
                for sk in subkeys[:8]:
                    print(f"    {sk}")
                if len(subkeys) > 8:
                    print(f"    ... +{len(subkeys) - 8} more")
            print()
        return

    # Navigate to the section
    current = config
    parts = section.strip("/").split("/")
    for part in parts:
        if isinstance(current, dict):
            matched = None
            for key in current:
                clean = key.split(":")[-1] if ":" in key else key
                if clean == part:
                    matched = key
                    break
            if matched:
                current = current[matched]
            else:
                print(f"Section not found: {part}")
                print(f"Available: {[k.split(':')[-1] for k in current.keys()]}")
                return 1
        elif isinstance(current, list):
            found = False
            for item in current:
                if isinstance(item, dict):
                    for id_field in ["name", "address", "id", "community-set-name"]:
                        if str(item.get(id_field)) == part:
                            current = item
                            found = True
                            break
                if found:
                    break
            if not found:
                ids = []
                for item in current:
                    if isinstance(item, dict):
                        for f in ["name", "address", "id"]:
                            if f in item:
                                ids.append(str(item[f]))
                                break
                print(f"Not found: {part}")
                print(f"Available: {ids}")
                return 1

    # Display the result
    _show_section(current)


def _show_section(data, indent=0):
    """Display structured data readably."""
    p = "  " * indent
    if isinstance(data, dict):
        for key in data:
            clean = key.split(":")[-1] if ":" in key else key
            val = data[key]
            if isinstance(val, dict):
                print(f"{p}{clean}:")
                _show_section(val, indent + 1)
            elif isinstance(val, list):
                if not val:
                    print(f"{p}{clean}: []")
                elif all(not isinstance(i, (dict, list)) for i in val):
                    print(f"{p}{clean}: {val}")
                else:
                    print(f"{p}{clean}:")
                    for item in val:
                        _show_section(item, indent + 1)
                        if isinstance(item, dict):
                            print(f"{p}  ---")
            else:
                print(f"{p}{clean}: {val}")
    elif isinstance(data, list):
        for item in data:
            _show_section(item, indent)
            if isinstance(item, dict):
                print(f"{p}---")
    else:
        print(f"{p}{data}")


def cmd_status(args):
    """Show all devices and their config state."""
    inventory = load_inventory()
    print(f"{'Device':<20} {'Hostname':<18} {'Driver':<18} {'Config File'}")
    print("-" * 75)
    for name, device in inventory.items():
        path = config_path(name)
        if path.exists():
            size = path.stat().st_size
            state = f"{size // 1024}KB"
        else:
            state = "not pulled"
        print(f"{name:<20} {device.get('hostname', '?'):<18} {device.get('driver', '?'):<18} {state}")


def _git(cmd):
    """Run a git command and return stdout."""
    result = subprocess.run(
        ["git"] + cmd,
        cwd=str(REPO_ROOT),
        capture_output=True,
        text=True,
    )
    return result.stdout.strip(), result.returncode


def cmd_history(args):
    """Show change history for a device."""
    device_name = args.device
    path = f"configs/{device_name}.json"
    count = args.count

    output, rc = _git(["log", f"-{count}", "--pretty=format:%h  %ar  %s", "--", path])
    if rc != 0 or not output:
        print(f"No history for {device_name}")
        return

    print(f"History for {device_name}:")
    print()
    lines = output.strip().split("\n")
    for i, line in enumerate(lines):
        marker = "  (current)" if i == 0 else ""
        print(f"  {i}: {line}{marker}")

    print()
    print(f"To rollback: nsci rollback {device_name} <number>")
    print(f"To see diff: nsci history {device_name} --diff <number>")

    # Show diff for a specific version if requested
    if args.diff is not None:
        idx = args.diff
        if idx >= len(lines):
            print(f"Error: only {len(lines)} versions available")
            return 1

        commit_hash = lines[idx].split()[0]

        if idx == 0:
            # Diff current vs previous
            diff_out, _ = _git(["diff", f"{commit_hash}~1", commit_hash, "--", path])
        else:
            # Diff that version vs the one before it
            diff_out, _ = _git(["diff", f"{commit_hash}~1", commit_hash, "--", path])

        if diff_out:
            print()
            print(f"Changes in version {idx} ({commit_hash}):")
            print("-" * 60)
            for line in diff_out.split("\n"):
                if line.startswith("+") and not line.startswith("+++"):
                    print(f"  \033[32m{line}\033[0m")  # green
                elif line.startswith("-") and not line.startswith("---"):
                    print(f"  \033[31m{line}\033[0m")  # red
                elif line.startswith("@@"):
                    print(f"  \033[36m{line}\033[0m")  # cyan
            print("-" * 60)
        else:
            print(f"No diff available for version {idx}")


def cmd_rollback(args):
    """Rollback a device to a previous config version and optionally push."""
    device_name = args.device
    path = f"configs/{device_name}.json"
    version = args.version

    # Get commit history for this file
    output, rc = _git(["log", "--pretty=format:%H  %ar  %s", "--", path])
    if rc != 0 or not output:
        print(f"No history for {device_name}")
        return 1

    commits = output.strip().split("\n")

    if version >= len(commits):
        print(f"Error: only {len(commits)} versions available (0-{len(commits)-1})")
        return 1

    if version == 0:
        print(f"Version 0 is already the current config.")
        return 0

    target_hash = commits[version].split()[0]
    target_desc = commits[version]

    print(f"Rolling back {device_name} to version {version}:")
    print(f"  {target_desc}")
    print()

    # Show what will change
    current_hash = commits[0].split()[0]
    diff_out, _ = _git(["diff", current_hash, target_hash, "--", path])
    if diff_out:
        added = sum(1 for l in diff_out.split("\n") if l.startswith("+") and not l.startswith("+++"))
        removed = sum(1 for l in diff_out.split("\n") if l.startswith("-") and not l.startswith("---"))
        print(f"  Changes: +{added} lines, -{removed} lines")
    else:
        print(f"  No differences (configs are identical)")
        return 0

    # Restore the file from that commit
    file_content, rc = _git(["show", f"{target_hash}:{path}"])
    if rc != 0:
        print(f"Error: could not read {path} from commit {target_hash}")
        return 1

    # Write it
    config_path(device_name).write_text(file_content)
    print(f"  Restored configs/{device_name}.json to version {version}")

    # Commit the rollback
    _git(["add", path])
    msg = f"Rollback {device_name} to version {version} ({target_hash[:7]})"
    _git(["commit", "-m", msg])
    print(f"  Committed: {msg}")

    # Push to device if requested
    if args.push:
        print()
        print(f"Pushing rollback to {device_name}...")
        device = get_device(device_name)
        config = json.loads(file_content)
        try:
            gnmi_push(device, config)
            print(f"  PUSHED to device — {device_name} restored to version {version}")
        except Exception as e:
            print(f"  PUSH FAILED: {e}")
            print(f"  Config file is rolled back but device was not updated.")
            print(f"  Run 'nsci push {device_name}' to retry.")
            return 1

        # Push to Git — try current branch first, fall back to rollback branch
        _, rc = _git(["push"])
        if rc == 0:
            print(f"  PUSHED to Git — repo is in sync")
        else:
            # Direct push to main likely blocked by branch protection.
            # Create a rollback branch and push there instead.
            import time as _t
            branch = f"rollback/{device_name}-{int(_t.time())}"
            _git(["checkout", "-b", branch])
            _, rc2 = _git(["push", "-u", "origin", branch])
            _git(["checkout", "-"])  # go back to previous branch
            if rc2 == 0:
                print(f"  PUSHED to Git branch: {branch}")
                print(f"  Open a PR to merge the rollback into main.")
            else:
                print(f"  Git push failed — run 'git push' manually to sync the repo")
    else:
        print()
        print(f"Config file rolled back (local only). Next steps:")
        print(f"  nsci push {device_name}       ← apply to device now")
        print(f"  git push                       ← sync repo (CI will deploy)")
        print(f"  nsci push ... && git push      ← both")


def cmd_library(args):
    """Browse available service templates."""
    if not LIBRARY_DIR.exists():
        print("No library found.")
        return

    if args.service:
        service_dir = LIBRARY_DIR / args.service
        if not service_dir.exists():
            print(f"Service '{args.service}' not found.")
            return 1
        schema_path = service_dir / "schema.yaml"
        if schema_path.exists():
            schema = yaml.safe_load(open(schema_path))
        else:
            schema = {}

        print(f"Service: {schema.get('name', args.service)}")
        print(f"Description: {schema.get('description', '')}")
        print(f"Platforms: {', '.join(schema.get('platforms', []))}")
        print()
        for var_name, var_def in schema.get("variables", {}).items():
            if isinstance(var_def, dict):
                req = "required" if var_def.get("required") else "optional"
                print(f"  {var_name} ({var_def.get('type', '?')}, {req}): {var_def.get('description', '')}")
    else:
        print(f"{'Service':<25} {'Platforms':<25} Description")
        print("-" * 80)
        for d in sorted(LIBRARY_DIR.iterdir()):
            if not d.is_dir():
                continue
            schema_path = d / "schema.yaml"
            if schema_path.exists():
                schema = yaml.safe_load(open(schema_path))
            else:
                schema = {}
            name = schema.get("name", d.name)
            platforms = ", ".join(schema.get("platforms", []))
            desc = schema.get("description", "")
            print(f"{name:<25} {platforms:<25} {desc}")


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(
        prog="nsci",
        description="NetStacks CI — Git-native network config management",
    )
    sub = parser.add_subparsers(dest="command")

    p = sub.add_parser("pull", help="Pull device config into configs/<device>.json")
    p.add_argument("device", help="Device name from inventory")

    p = sub.add_parser("push", help="Push config file to a single device")
    p.add_argument("device", help="Device name from inventory")

    p = sub.add_parser("deploy", help="Deploy to multiple devices (parallel + atomic)")
    p.add_argument("devices", nargs="+", help="Device names to deploy")
    p.add_argument("--workers", type=int, default=10, help="Parallel workers (default: 10)")
    p.add_argument("--no-atomic", action="store_true", help="Skip rollback on failure")

