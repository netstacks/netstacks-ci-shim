def cmd_pull(args):
    """Pull device config into configs/<device>.json."""
    device_name = args.device
    device = get_device(device_name)
    driver = load_driver(device["driver"])
    transport = driver["transport"] if driver else "gnmi"

    print(f"Pulling config from {device_name} ({device['hostname']}) via {transport}...")

    config, fmt = transport_pull(device_name)

    if fmt == "json":
        path = save_config(device_name, config)
        keys = sorted(k.split(":")[-1] for k in config.keys())
        print(f"Saved: {path.relative_to(REPO_ROOT)}")
        print(f"Sections: {', '.join(keys)}")
    else:
        # NETCONF returns XML — save as .xml
        CONFIGS_DIR.mkdir(parents=True, exist_ok=True)
        path = CONFIGS_DIR / f"{device_name}.xml"
        with open(path, "w") as f:
            f.write(config)
        print(f"Saved: {path.relative_to(REPO_ROOT)}")


def cmd_pull_snapshot(args):
    """Pull device config into snapshots/<device> (pre-deploy backup)."""
    device_name = args.device
    device = get_device(device_name)

    print(f"Snapshotting {device_name} ({device['hostname']})...")

    config, fmt = transport_pull(device_name)

    SNAPSHOTS_DIR.mkdir(parents=True, exist_ok=True)
    if fmt == "json":
        path = SNAPSHOTS_DIR / f"{device_name}.json"
        with open(path, "w") as f:
            json.dump(config, f, indent=2)
            f.write("\n")
    else:
        path = SNAPSHOTS_DIR / f"{device_name}.xml"
        with open(path, "w") as f:
            f.write(config)
    print(f"Saved: {path.relative_to(REPO_ROOT)}")


def _push_one_device(device_name):
    """Push configs/<device>.json to a device. Returns (success, error)."""
    device = get_device(device_name)
    driver = load_driver(device["driver"])
    transport = driver["transport"] if driver else "gnmi"

    print(f"Pushing config to {device_name} ({device['hostname']}) via {transport}...")

    try:
        if transport == "gnmi":
            config = load_config(device_name)
            result = gnmi_push(device, config)
            op = result["response"][0]["op"]
            print(f"  {device_name}: gNMI Set {op}")
        elif transport == "netconf":
            xml_path = CONFIGS_DIR / f"{device_name}.xml"
            if xml_path.exists():
                with open(xml_path) as f:
                    xml_config = f.read()
            else:
                print(f"  {device_name}: FAILED — no .xml config file")
                return False, f"no config file configs/{device_name}.xml"
            netconf_push(device, xml_config)
            print(f"  {device_name}: NETCONF edit-config OK")
        else:
            print(f"  {device_name}: FAILED — transport '{transport}' not supported")
            return False, f"transport '{transport}' not supported"

        return True, None
    except Exception as e:
        print(f"  {device_name}: PUSH FAILED — {e}")
        return False, str(e)


def _sync_one_device(device_name):
    """Pull config back from device so configs/ reflects actual device state."""
    try:
        config_back, fmt = transport_pull(device_name)
        if fmt == "json":
            save_config(device_name, config_back)
        print(f"  {device_name}: synced")
    except Exception as e:
        print(f"  {device_name}: sync failed — {e}")


def cmd_push(args):
    """Push configs/ to one or more devices."""
    device_names = args.devices
    multi = len(device_names) > 1

    if not args.full_replace:
        print(f"ERROR: full config replace requires --full-replace")
        print(f"  This replaces the ENTIRE running config on the device.")
        print(f"  If that's what you want: nsci push {' '.join(device_names)} --full-replace")
        return 1

    if multi:
        workers = min(len(device_names), args.workers)
        atomic = not args.no_atomic

        print(f"Full config replace to {len(device_names)} devices (workers={workers}, atomic={atomic})")
        print(f"  Devices: {', '.join(device_names)}")
        print()

        # --- Pre-flight: save rollback snapshots ---
        print("Pre-flight (saving rollback snapshots)...")
        rollbacks = {}
        preflight_failures = []

        def preflight_one(name):
            try:
                config, fmt = transport_pull(name)
                return name, config, fmt, None
            except Exception as e:
                return name, None, None, str(e)

        with concurrent.futures.ThreadPoolExecutor(max_workers=workers) as pool:
            futures = {pool.submit(preflight_one, n): n for n in device_names}
            for future in concurrent.futures.as_completed(futures):
                name, config, fmt, error = future.result()
                if error:
                    print(f"  {name}: FAILED pre-flight — {error}")
                    preflight_failures.append(name)
                else:
                    rollbacks[name] = (config, fmt)
                    print(f"  {name}: OK (snapshot saved)")

        if preflight_failures:
            print(f"\nABORTED: {len(preflight_failures)} devices failed pre-flight. No changes made.")
            return 1

        print()

        # --- Push ---
        print("Pushing configs...")
        push_results = {}

        def push_one(name):
            try:
                device = get_device(name)
                driver = load_driver(device["driver"])
                transport = driver["transport"]
                if transport == "gnmi":
                    config = load_config(name)
                    gnmi_push(device, config)
                elif transport == "netconf":
                    xml_path = CONFIGS_DIR / f"{name}.xml"
                    if not xml_path.exists():
                        return name, False, f"no config file configs/{name}.xml"
                    with open(xml_path) as f:
                        netconf_push(device, f.read())
                else:
                    return name, False, f"transport '{transport}' not supported"
                return name, True, None
            except Exception as e:
                return name, False, str(e)

        with concurrent.futures.ThreadPoolExecutor(max_workers=workers) as pool:
            futures = {pool.submit(push_one, n): n for n in device_names}
            for future in concurrent.futures.as_completed(futures):
                name, success, error = future.result()
                push_results[name] = (success, error)
                if success:
                    print(f"  {name}: PUSHED")
                else:
                    print(f"  {name}: FAILED — {error}")

        failed = [n for n, (s, _) in push_results.items() if not s]
        succeeded = [n for n, (s, _) in push_results.items() if s]
        print()

        # --- Validate ---
        if succeeded:
            print("Validating...")
            validate_failures = []

            def validate_one(name):
                try:
                    live_config, _ = transport_pull(name)
                    local_config = load_config(name)
                    local_str = json.dumps(local_config, sort_keys=True)
                    live_str = json.dumps(live_config, sort_keys=True)
                    return name, local_str == live_str, None
                except Exception as e:
                    return name, False, str(e)

            with concurrent.futures.ThreadPoolExecutor(max_workers=workers) as pool:
                futures = {pool.submit(validate_one, n): n for n in succeeded}
                for future in concurrent.futures.as_completed(futures):
                    name, valid, error = future.result()
                    if valid:
                        print(f"  {name}: IN SYNC")
                    else:
                        reason = error or "config mismatch"
                        print(f"  {name}: VALIDATION FAILED — {reason}")
                        validate_failures.append(name)

            failed.extend(validate_failures)
            print()

        # --- Rollback if atomic and failures ---
        if failed and atomic:
            print(f"ROLLING BACK ({len(failed)} failures, atomic mode)")
            print(f"  Restoring all {len(device_names)} devices to pre-flight state...")

            def rollback_one(name):
                config, fmt = rollbacks[name]
                try:
                    transport_push_full(name, config)
                    return name, True, None
                except Exception as e:
                    return name, False, str(e)

            with concurrent.futures.ThreadPoolExecutor(max_workers=workers) as pool:
                futures = {pool.submit(rollback_one, n): n for n in device_names}
                for future in concurrent.futures.as_completed(futures):
                    name, success, error = future.result()
                    if success:
                        print(f"  {name}: ROLLED BACK")
                    else:
                        print(f"  {name}: ROLLBACK FAILED — {error} (MANUAL INTERVENTION NEEDED)")

            print(f"\nPUSH FAILED — all devices rolled back to previous state.")
            return 1

        elif failed and not atomic:
            print(f"WARNING: {len(failed)} devices failed (non-atomic mode, no rollback)")
            print(f"  Failed: {', '.join(failed)}")
            print(f"  Succeeded: {', '.join(succeeded)}")
            if succeeded:
                print()
                print("Syncing configs/ for succeeded devices...")
                for name in succeeded:
                    _sync_one_device(name)
            return 1

        else:
            print("Syncing configs/...")
            for name in succeeded:
                _sync_one_device(name)
            print()
            print(f"PUSH SUCCEEDED — {len(succeeded)} devices updated.")
            return 0

    else:
        # Single device push
        device_name = device_names[0]
        success, error = _push_one_device(device_name)
        if not success:
            return 1

        # Sync
        _sync_one_device(device_name)
        return 0




