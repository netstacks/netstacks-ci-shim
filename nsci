def _complete_devices(**kwargs):
    try:
        inv = yaml.safe_load(open(INVENTORY_FILE))
        return sorted(inv.get("devices", {}).keys())
    except Exception:
        return []


def _complete_stacks(**kwargs):
    try:
        return sorted(d.name for d in STACKS_DIR.iterdir() if d.is_dir())
    except Exception:
        return []


def _complete_services(**kwargs):
    try:
        return sorted(d.name for d in LIBRARY_DIR.iterdir() if d.is_dir())
    except Exception:
        return []


# ---------------------------------------------------------------------------
# Inventory & Drivers
# ---------------------------------------------------------------------------

def load_inventory():
    with open(INVENTORY_FILE) as f:
        return yaml.safe_load(f).get("devices", {})


def get_device(name):
    inv = load_inventory()
    if name not in inv:
        print(f"Error: device '{name}' not in inventory")
        sys.exit(1)
    return inv[name]


TRANSPORT_FORMAT = {
    "gnmi": "json",
    "netconf": "xml",
    "rest_api": "rest",
    "eapi": "json",
}


def load_driver(driver_name):
    """Load a driver definition from drivers/."""
    driver_path = DRIVERS_DIR / driver_name / "driver.yaml"
    if not driver_path.exists():
        return None
    with open(driver_path) as f:
        return yaml.safe_load(f)


def get_transport(device_name):
    """Get the transport type for a device."""
    device = get_device(device_name)
    driver = load_driver(device["driver"])
    if not driver:
        return None
    return driver["transport"]


# ---------------------------------------------------------------------------
# Template resolution & rendering
# ---------------------------------------------------------------------------

def resolve_template(service_name, driver_name, operation="merge"):
    """Pick the right template for a service + driver combo.

    For delete operations, lookup order:
      1. delete.{platform}.{format}.j2  (vendor-specific delete)
      2. delete.{format}.j2             (generic delete)
      3. Falls through to standard templates if no delete template exists

    Standard lookup order:
      1. template.{platform}.{format}.j2  (vendor-specific)
      2. template.{format}.j2             (generic OpenConfig)

    Returns (template_path, None) or (None, error_string).
    """
    driver = load_driver(driver_name)
    if not driver:
        return None, f"driver '{driver_name}' not found in drivers/"
    platform = driver["platform"]
    transport = driver["transport"]
    fmt = TRANSPORT_FORMAT.get(transport)
    if not fmt:
        return None, f"unknown transport '{transport}' for driver '{driver_name}'"

    service_dir = LIBRARY_DIR / service_name

    # For delete operations, try delete-specific templates first
    if operation == "delete":
        del_specific = service_dir / f"delete.{platform}.{fmt}.j2"
        if del_specific.exists():
            return del_specific, None
        del_generic = service_dir / f"delete.{fmt}.j2"
        if del_generic.exists():
            return del_generic, None
        # No delete template — fall through to deploy template
        # OpenConfig: nsci auto-injects nc:operation="delete" on list items
        # Vendor-native: nsci swaps existing nc:operation values to "delete"

    # Try platform-specific first
    specific = service_dir / f"template.{platform}.{fmt}.j2"
    if specific.exists():
        return specific, None

    # Fall back to generic
    generic = service_dir / f"template.{fmt}.j2"
    if generic.exists():
        return generic, None

    return None, f"no {fmt} template for service '{service_name}' (tried {specific.name}, {generic.name})"


def load_schema(service_name):
    """Load a service schema from library/."""
    schema_path = LIBRARY_DIR / service_name / "schema.yaml"
    if not schema_path.exists():
        return None
    with open(schema_path) as f:
        return yaml.safe_load(f)


def validate_variables(schema, variables, device_name=None):
    """Validate variables against a schema. Returns list of errors."""
    errors = []
    schema_vars = schema.get("variables", {})
    for var_name, var_def in schema_vars.items():
        if not isinstance(var_def, dict):
            continue
        if var_def.get("required") and var_name not in variables:
            scope = var_def.get("scope", "shared")
            if device_name and scope == "shared":
                continue  # shared vars checked separately
            errors.append(f"missing required variable '{var_name}'" +
                          (f" for {device_name}" if device_name else ""))
    return errors


def render_template(template_path, variables):
    """Render a Jinja2 template with the given variables.

    XML templates (.xml.j2) get automatic escaping of &, <, >, " in variables.
    JSON and other templates render without escaping.
    """
    template_path = Path(template_path)
    is_xml = template_path.name.endswith(".xml.j2")
    env = Environment(
        loader=FileSystemLoader(str(template_path.parent)),
        autoescape=is_xml,
    )
    tmpl = env.get_template(template_path.name)
    return tmpl.render(**variables)


# ---------------------------------------------------------------------------
# gNMI transport
# ---------------------------------------------------------------------------

def gnmi_connect(device):
    from pygnmi.client import gNMIclient
    cred = device["credential"]
    return gNMIclient(
        target=(device["hostname"], device.get("gnmi_port", 6030)),
        username=cred["username"],
        password=cred["password"],
        insecure=True,
        skip_verify=True,
        gnmi_timeout=30,
    )


def gnmi_pull(device):
    """Pull full config from device via gNMI Get."""
    with gnmi_connect(device) as gc:
        result = gc.get(path=["/"], datatype="config", encoding="json_ietf")
        return result["notification"][0]["update"][0]["val"]


def gnmi_push(device, config):
    """Push full config to device via gNMI Set replace."""
    with gnmi_connect(device) as gc:
        result = gc.set(replace=[("/", config)], encoding="json_ietf")
        return result


def _gnmi_strip_origin(path):
    """Strip YANG module origin prefix from gNMI path.

    Arista (and others) reject Set requests with origin-prefixed paths like
    'openconfig-system:system/ntp'. Convert to '/system/ntp' by stripping
    the 'module-name:' prefix from the first path element.
    """
    path = path.lstrip("/")
    parts = path.split("/", 1)
    if ":" in parts[0]:
        parts[0] = parts[0].split(":", 1)[1]
    return "/" + "/".join(parts)


def gnmi_replace_path(device, path, config):
    """Replace a specific config section via gNMI Set replace at path."""
    with gnmi_connect(device) as gc:
        result = gc.set(replace=[(_gnmi_strip_origin(path), config)], encoding="json_ietf")
        return result


def gnmi_update_path(device, path, config):
    """Merge config into a section via gNMI Set update at path."""
    with gnmi_connect(device) as gc:
        result = gc.set(update=[(_gnmi_strip_origin(path), config)], encoding="json_ietf")
        return result


def gnmi_delete_path(device, path):
    """Delete a config section via gNMI Set delete at path."""
    with gnmi_connect(device) as gc:
        result = gc.set(delete=[_gnmi_strip_origin(path)], encoding="json_ietf")
        return result


def gnmi_get_section(device, path):
    """Pull a specific config section via gNMI Get."""
    with gnmi_connect(device) as gc:
        result = gc.get(path=[_gnmi_strip_origin(path)], datatype="config", encoding="json_ietf")
        return result["notification"][0]["update"][0]["val"]


# ---------------------------------------------------------------------------
# NETCONF transport
# ---------------------------------------------------------------------------

def netconf_connect(device):
    from ncclient import manager
    driver = load_driver(device["driver"])
    nc_config = driver.get("netconf", {}) if driver else {}
    cred = device["credential"]
    return manager.connect(
        host=device["hostname"],
        port=nc_config.get("port", 830),
        username=cred["username"],
        password=cred["password"],
        hostkey_verify=nc_config.get("hostkey_verify", False),
    )


def _netconf_has_commit_confirm(device):
    """Check if device driver supports commit-confirm."""
    driver = load_driver(device["driver"])
    if not driver:
        return False, 0
    caps = driver.get("capabilities", {})
    supported = caps.get("commit_confirm", False)
    timeout = caps.get("commit_confirm_timeout", 120)
    has_candidate = caps.get("candidate_datastore", False)
    return supported and has_candidate, timeout


def netconf_pull(device):
    """Pull full config from device via NETCONF get-config."""
    with netconf_connect(device) as m:
        result = m.get_config(source="running")
        return result.data_xml


def netconf_push(device, xml_config):
    """Push full config to device via NETCONF edit-config (replace).

    Uses commit-confirm if the device supports it:
      1. Lock candidate → edit-config → confirmed commit (timeout)
      2. Caller validates → netconf_commit_confirm() to finalize
      3. If caller doesn't confirm, device auto-rolls back after timeout
    Without commit-confirm: edit-config directly on running.
    """
    commit_confirm, timeout = _netconf_has_commit_confirm(device)

    if commit_confirm:
        with netconf_connect(device) as m:
            m.lock("candidate")
            try:
                m.discard_changes()
                m.edit_config(
                    target="candidate",
                    config=xml_config,
                    default_operation="replace",
                )
                m.commit(confirmed=True, timeout=str(timeout))
                return {"confirmed_commit": True, "timeout": timeout, "session": None}
            except Exception:
                m.discard_changes()
                m.unlock("candidate")
                raise
    else:
        with netconf_connect(device) as m:
            result = m.edit_config(
                target="running",
                config=xml_config,
                default_operation="replace",
            )
            return {"confirmed_commit": False}


def netconf_update(device, xml_config):
    """Push partial config to device via NETCONF edit-config.

    The XML template includes nc:operation="replace" on the root element,
    so the device replaces that entire section (not just merge).

    Uses commit-confirm if the device supports it:
      1. Lock candidate → edit-config → commit confirmed (timer starts)
      2. Caller validates → netconf_confirm() to finalize
      3. If caller doesn't confirm, device auto-rolls back after timeout
    """
    commit_confirm, timeout = _netconf_has_commit_confirm(device)

    if commit_confirm:
        with netconf_connect(device) as m:
            m.lock("candidate")
            try:
                m.discard_changes()
                m.edit_config(
                    target="candidate",
                    config=xml_config,
                )
                m.commit(confirmed=True, timeout=str(timeout))
                return {"confirmed_commit": True, "timeout": timeout}
            except Exception:
                m.discard_changes()
                m.unlock("candidate")
                raise
    else:
        with netconf_connect(device) as m:
            result = m.edit_config(
                target="running",
                config=xml_config,
            )
            return {"confirmed_commit": False}


def netconf_confirm(device):
    """Send confirming commit to finalize a confirmed-commit."""
    with netconf_connect(device) as m:
        m.commit()
        m.unlock("candidate")


# ---------------------------------------------------------------------------
# Transport-agnostic operations
# ---------------------------------------------------------------------------

def transport_pull(device_name):
    """Pull full config from device using its driver's transport.
    Returns (config, format) where format is 'json' or 'xml'.
    """
    device = get_device(device_name)
    driver = load_driver(device["driver"])
    if not driver:
        raise ValueError(f"no driver for {device_name}")
    transport = driver["transport"]

    if transport == "gnmi":
        return gnmi_pull(device), "json"
    elif transport == "netconf":
        return netconf_pull(device), "xml"
    else:
        raise ValueError(f"pull not supported for transport '{transport}'")


def transport_push_full(device_name, config):
    """Push full config to device (replace). Config is dict for gNMI, str for NETCONF."""
    device = get_device(device_name)
    driver = load_driver(device["driver"])
    transport = driver["transport"]

    if transport == "gnmi":
        return gnmi_push(device, config)
    elif transport == "netconf":
        return netconf_push(device, config)
    else:
        raise ValueError(f"full push not supported for transport '{transport}'")


# OpenConfig YANG list keys — used to build per-item gNMI delete paths
_OC_LIST_KEYS = {
    "static": "prefix",
    "server": "address",
    "neighbor": "neighbor-address",
    "community-set": "community-set-name",
    "community": "name",
    "policy-definition": "name",
    "statement": "name",
}


def _gnmi_delete_paths(config, base_path):
    """Walk rendered JSON and build per-list-item gNMI delete paths.

    Instead of deleting the whole container (which nukes everything),
    build specific paths like:
      /static-routes/static[prefix=10.200.1.0/24]
      /bgp/neighbors/neighbor[neighbor-address=172.16.0.1]

    Returns a list of paths to delete. If no list items found, returns
    the base path (deletes the whole section).
    """
    paths = []

    def _walk(obj, path):
        if isinstance(obj, dict):
            for key, val in obj.items():
                if isinstance(val, list) and key in _OC_LIST_KEYS:
                    # This is a keyed list — build per-item paths
                    list_key = _OC_LIST_KEYS[key]
                    for item in val:
                        if isinstance(item, dict) and list_key in item:
                            item_path = f"{path}/{key}[{list_key}={item[list_key]}]"
                            paths.append(item_path)
                elif isinstance(val, dict):
                    _walk(val, f"{path}/{key}")
                elif isinstance(val, list):
                    # List without a known key — can't do per-item delete
                    _walk_list_items(val, f"{path}/{key}")

    def _walk_list_items(lst, path):
        for item in lst:
            if isinstance(item, dict):
                _walk(item, path)

    _walk(config, base_path)
    return paths if paths else [base_path]


def transport_push_partial(device_name, rendered_output, template_path, target_path=None, operation="merge"):
    """Push rendered template to device via the right transport.

    The operation comes from the service schema (template creator's decision):
      merge:   gNMI Set update / NETCONF default merge
      replace: gNMI Set replace / NETCONF nc:operation="replace" (set in template XML)
      delete:  gNMI Set delete per list item / NETCONF nc:operation="delete" (template XML)

    Returns dict with push metadata including whether confirmed_commit is pending.
    """
    device = get_device(device_name)
    driver = load_driver(device["driver"])
    transport = driver["transport"]

    if transport == "gnmi":
        if not target_path:
            raise ValueError(f"no target path for gNMI — schema needs 'path' field")
        if operation == "delete":
            # Build per-item delete paths from rendered JSON
            if rendered_output:
                config = json.loads(rendered_output)
                delete_paths = _gnmi_delete_paths(config, target_path)
            else:
                delete_paths = [target_path]
            for path in delete_paths:
                gnmi_delete_path(device, path)
        elif operation == "replace":
            config = json.loads(rendered_output)
            gnmi_replace_path(device, target_path, config)
        else:
            config = json.loads(rendered_output)
            gnmi_update_path(device, target_path, config)
        return {"confirmed_commit": False}
    elif transport == "netconf":
        # For NETCONF delete: if no nc:operation="delete" in template, inject it
        if operation == "delete" and 'nc:operation="delete"' not in rendered_output:
            rendered_output = _inject_xml_delete(rendered_output)
        return netconf_update(device, rendered_output)
    else:
        raise ValueError(f"partial push not supported for transport '{transport}'")


def transport_confirm(device_name):
    """Send confirming commit for devices with pending confirmed-commits."""
    device = get_device(device_name)
    driver = load_driver(device["driver"])
    transport = driver["transport"]

    if transport == "netconf":
        netconf_confirm(device)
    # gNMI doesn't need confirm — changes are immediate


