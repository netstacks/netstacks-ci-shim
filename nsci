                req = "required" if var_def.get("required") else "optional"
                scope = var_def.get("scope", "shared")
                print(f"  {var_name} ({var_def.get('type', '?')}, {req}, {scope}): {var_def.get('description', '')}")
    else:
        print(f"{'Service':<25} {'Templates':<25} Description")
        print("-" * 80)
        for d in sorted(LIBRARY_DIR.iterdir()):
            if not d.is_dir():
                continue
            schema_path = d / "schema.yaml"
            if schema_path.exists():
                schema = yaml.safe_load(open(schema_path))
            else:
                schema = {}
            name = schema.get("name", d.name)
            templates = ", ".join(schema.get("templates", {}).keys())
            desc = schema.get("description", "")
            print(f"{name:<25} {templates:<25} {desc}")


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    # ? help — network engineers expect '?' for context-sensitive help
    if len(sys.argv) > 1 and sys.argv[-1] == "?":
        sys.argv[-1] = "--help"

    parser = argparse.ArgumentParser(
        prog="nsci",
        description="NetStacks CI — Git-native network config management",
        epilog="Tip: use '?' for help (nsci push ?) and Tab for completion.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sub = parser.add_subparsers(dest="command")

    # --- Device operations ---
    p = sub.add_parser("pull", help="Pull device config into configs/")
    p.add_argument("device", help="Device name from inventory").completer = _complete_devices

    p = sub.add_parser("pull-snapshot", help="Save device config to snapshots/ (pre-deploy backup)")
    p.add_argument("device", help="Device name from inventory").completer = _complete_devices

    p = sub.add_parser("push", help="Push config file to device(s) — full config replace")
    p.add_argument("devices", nargs="+", help="Device name(s) from inventory").completer = _complete_devices
    p.add_argument("--full-replace", action="store_true", help="Required — confirms full config replace")
    p.add_argument("--workers", type=int, default=10, help="Parallel workers for multi-device (default: 10)")
    p.add_argument("--no-atomic", action="store_true", help="Skip rollback on failure (multi-device only)")

    p = sub.add_parser("diff", help="Compare config file vs live device")
    p.add_argument("device", help="Device name from inventory").completer = _complete_devices

    p = sub.add_parser("validate", help="Check if device matches config file")
    p.add_argument("device", help="Device name from inventory").completer = _complete_devices

    p = sub.add_parser("show", help="Browse device config readably")
    p.add_argument("device", help="Device name from inventory").completer = _complete_devices
    p.add_argument("section", nargs="?", help="Config section path (e.g. system/ntp)")

    # --- Stack operations ---
    p = sub.add_parser("stack-render", help="Render all templates in a stack (dry run)")
    p.add_argument("stack", help="Stack name").completer = _complete_stacks
    p.add_argument("--delete", action="store_true", help="Show delete payloads instead of deploy")

    p = sub.add_parser("stack-deploy", help="Render + push a stack to devices")
    p.add_argument("stack", help="Stack name").completer = _complete_stacks

    p = sub.add_parser("stack-delete", help="Remove all config deployed by a stack")
    p.add_argument("stack", help="Stack name").completer = _complete_stacks

    sub.add_parser("stack-list", help="List available stacks")

    # --- History ---
    p = sub.add_parser("history", help="Show change history for a device")
    p.add_argument("device", help="Device name from inventory").completer = _complete_devices
    p.add_argument("--count", type=int, default=10, help="Number of versions to show")
    p.add_argument("--diff", type=int, default=None, metavar="N", help="Show diff for version N")

    p = sub.add_parser("rollback", help="Rollback device to a previous version")
    p.add_argument("device", help="Device name from inventory").completer = _complete_devices
    p.add_argument("version", type=int, help="Version number from 'nsci history'")
    p.add_argument("--no-push", action="store_true", help="Only restore the file, don't push to device")

    # --- Info ---
    sub.add_parser("status", help="Show all devices and config state")

    p = sub.add_parser("library", help="Browse service templates")
    p.add_argument("service", nargs="?", help="Service name for details").completer = _complete_services

    # Tab completion (requires: pip install argcomplete)
    try:
        import argcomplete
        argcomplete.autocomplete(parser)
    except ImportError:
        pass

    args = parser.parse_args()
    if not args.command:
        parser.print_help()
        sys.exit(0)

    cmds = {
        "pull": cmd_pull,
        "pull-snapshot": cmd_pull_snapshot,
        "push": cmd_push,
        "stack-render": cmd_stack_render,
        "stack-deploy": cmd_stack_deploy,
        "stack-delete": cmd_stack_delete,
        "stack-list": cmd_stack_list,
        "diff": cmd_diff,
        "validate": cmd_validate,
        "show": cmd_show,
        "history": cmd_history,
        "rollback": cmd_rollback,
        "status": cmd_status,
        "library": cmd_library,
    }
    sys.exit(cmds[args.command](args) or 0)


if __name__ == "__main__":
    main()
