def _load_stack(stack_name):
    """Load and return a stack definition. Exits on error."""
    stack_path = STACKS_DIR / stack_name / "stack.yaml"
    if not stack_path.exists():
        print(f"Stack '{stack_name}' not found.")
        if STACKS_DIR.exists():
            available = [d.name for d in STACKS_DIR.iterdir() if (d / "stack.yaml").exists()]
            if available:
                print(f"Available: {', '.join(available)}")
        sys.exit(1)
    with open(stack_path) as f:
        return yaml.safe_load(f)


def _resolve_stack_services(stack):
    """Walk a stack and resolve each service × device into render jobs.

    Returns list of dicts:
      { service, device, driver, template_path, variables, errors }
    """
    inventory = load_inventory()
    jobs = []

    for svc_entry in stack.get("services", []):
        service_name = svc_entry["service"]
        # Stack can override operation to "delete" for teardown stacks
        stack_operation = svc_entry.get("operation")
        shared_vars = svc_entry.get("variables", {})
        devices_spec = svc_entry.get("devices", [])
        schema = load_schema(service_name)

        # Normalize devices: list of names or dict of name->overrides
        if isinstance(devices_spec, list):
            device_map = {name: {} for name in devices_spec}
        elif isinstance(devices_spec, dict):
            device_map = devices_spec
        else:
            device_map = {}

        for device_name, device_vars in device_map.items():
            if device_vars is None:
                device_vars = {}

            job = {
                "service": service_name,
                "device": device_name,
                "errors": [],
            }

            # Look up device in inventory
            if device_name not in inventory:
                job["errors"].append(f"device '{device_name}' not in inventory")
                jobs.append(job)
                continue

            device_info = inventory[device_name]
            driver_name = device_info.get("driver")
            job["driver"] = driver_name

            # Merge variables: shared + per-device (per-device wins)
            merged = {**shared_vars, **device_vars}
            job["variables"] = merged

            # Carry the target path and operation from the schema
            if schema:
                raw_path = schema.get("path", "")
                # Allow Jinja2 variables in schema path (e.g. network-instance[name={{ vrf }}])
                if "{{" in raw_path:
                    try:
                        from jinja2 import Environment
                        job["path"] = Environment().from_string(raw_path).render(**merged)
                    except Exception as e:
                        job["errors"].append(f"path render failed: {e}")
                        job["path"] = raw_path
                else:
                    job["path"] = raw_path
                # Stack operation: delete overrides schema. Otherwise schema decides.
                job["operation"] = stack_operation if stack_operation else schema.get("operation", "merge")
                # Skip variable validation for delete — not all vars are needed
                if job["operation"] != "delete":
                    errs = validate_variables(schema, merged, device_name)
                    job["errors"].extend(errs)
            else:
                job["path"] = None
                job["operation"] = stack_operation or "merge"

            # Resolve template (delete-aware: tries delete.*.j2 first)
            if job["operation"] == "delete":
                template_path, err = resolve_template(service_name, driver_name, operation="delete")
                job["template_path"] = template_path  # may be None — that's OK for gNMI delete
                if err and get_transport(device_name) == "netconf":
                    # NETCONF delete needs a template with nc:operation="delete"
                    job["errors"].append(f"delete requires a template for NETCONF: {err}")
            else:
                template_path, err = resolve_template(service_name, driver_name)
                if err:
                    job["errors"].append(err)
                job["template_path"] = template_path

            jobs.append(job)

    return jobs


import re as _re

# OpenConfig XML list item elements — nc:operation="delete" goes on these,
# not the container, so we only delete the specific items from the stack.
_OC_LIST_ELEMENTS = {
    "static", "server", "neighbor", "community-set", "community",
    "policy-definition", "statement", "filter",
}


def _inject_xml_delete(xml_str):
    """Convert rendered XML to delete mode.

    Two strategies based on template type:

    OpenConfig templates (xmlns contains 'openconfig.net'):
      Inject nc:operation="delete" on known list item elements (<static>,
      <neighbor>, <server>, etc.) so only the stack's items are removed.

    Vendor-native templates (Junos, etc.):
      Swap all existing nc:operation="..." to nc:operation="delete".
      Template creators must use explicit nc:operation on every operational
      element — if nsci can't see it, nsci can't delete it.
      Error if no nc:operation found (template needs explicit operations).

    Both strategies ensure xmlns:nc is declared on the root element.
    """
    is_openconfig = "openconfig.net" in xml_str

    # Ensure xmlns:nc is on the root element
    def _add_ns(match):
        tag = match.group(0)
        if 'xmlns:nc=' not in tag:
            tag = tag[:-1] + ' xmlns:nc="urn:ietf:params:xml:ns:netconf:base:1.0">'
        return tag
    xml_str = _re.sub(r'<[a-zA-Z][\w:-]*(?:\s[^>]*)?>', _add_ns, xml_str, count=1)

    if is_openconfig:
        # OpenConfig: inject nc:operation="delete" on known list item elements
        found_items = False
        def _inject_on_items(match):
            nonlocal found_items
            tag_name = match.group(1)
            full_tag = match.group(0)
            if tag_name in _OC_LIST_ELEMENTS and 'nc:operation=' not in full_tag:
                found_items = True
                return full_tag[:-1] + ' nc:operation="delete">'
            return full_tag
        xml_str = _re.sub(r'<([a-zA-Z][\w-]*)(?:\s[^>]*)?>',  _inject_on_items, xml_str)

        # Fallback: if no list items found, inject on root
        if not found_items:
            def _inject_root(match):
                tag = match.group(0)
                if 'nc:operation=' not in tag:
                    tag = tag[:-1] + ' nc:operation="delete">'
                return tag
            xml_str = _re.sub(r'<[a-zA-Z][\w:-]*(?:\s[^>]*)?>', _inject_root, xml_str, count=1)
    else:
        # Vendor-native: swap all existing nc:operation values to "delete"
        swapped = xml_str
        swapped = swapped.replace('nc:operation="replace"', 'nc:operation="delete"')
        swapped = swapped.replace('nc:operation="merge"', 'nc:operation="delete"')
        swapped = swapped.replace("nc:operation='replace'", 'nc:operation="delete"')
        swapped = swapped.replace("nc:operation='merge'", 'nc:operation="delete"')
        if swapped == xml_str:
            # No nc:operation found — template has no explicit operations
            raise ValueError(
                "non-OpenConfig template has no nc:operation attributes — "
                "add explicit nc:operation (merge/replace) to every operational "
                "element so nsci can swap them to delete at teardown time"
            )
        xml_str = swapped

    return xml_str


def _check_path_collisions(jobs):
    """Detect two services targeting the same device + path. Returns errors."""
    seen = {}
    errors = []
    for job in jobs:
        if job["errors"]:
            continue
        path = job.get("path")
        if not path:
            continue
        key = (job["device"], path)
        if key in seen:
            msg = (f"path collision: [{job['service']}] and [{seen[key]}] both target "
                   f"{job['device']} at {path} — concurrent push would race")
            job["errors"].append(msg)
            errors.append(msg)
        else:
            seen[key] = job["service"]
    return errors


def _render_jobs(jobs):
    """Render all jobs, adding 'rendered' and 'fmt' to each. Returns errors."""
    errors = _check_path_collisions(jobs)
    for job in jobs:
        if job["errors"]:
            errors.extend(job["errors"])
            continue

        # gNMI delete doesn't need a rendered payload — just the path
        if job.get("operation") == "delete" and not job.get("template_path"):
            job["rendered"] = ""
            job["fmt"] = "delete"
            continue

        try:
            job["rendered"] = render_template(job["template_path"], job["variables"])
            name = job["template_path"].name
            if name.endswith(".json.j2"):
                job["fmt"] = "json"
            elif name.endswith(".xml.j2"):
                job["fmt"] = "xml"
                # Vendor-native XML must have explicit nc:operation for delete support
                rendered = job["rendered"]
                if "openconfig.net" not in rendered and "nc:operation=" not in rendered:
                    msg = (
                        f"non-OpenConfig template '{name}' has no nc:operation attributes — "
                        f"add explicit nc:operation (merge/replace) to every operational "
                        f"element so stack-delete can swap them to delete"
                    )
                    job["errors"].append(msg)
                    errors.append(msg)
            else:
                job["fmt"] = "rest"
        except Exception as e:
            job["errors"].append(f"render failed: {e}")
            errors.append(str(e))
    return errors


